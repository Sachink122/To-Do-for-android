<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base Theme -->
    <style name="Theme.TodoApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/surface</item>
        
        <!-- Navigation bar color -->
        <item name="android:navigationBarColor">@color/surface</item>
        
        <!-- Background colors -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/on_background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        
        <!-- Error color -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>
        
        <!-- Window features -->
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
    </style>
    
    <!-- Text Appearances -->
    <style name="TextAppearance.TodoApp.Toolbar" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="TextAppearance.TodoApp.Headline4" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.TodoApp.Headline5" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.TodoApp.Headline6" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.TodoApp.Body1" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">sans-serif</item>
    </style>
    
    <style name="TextAppearance.TodoApp.Body2" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">sans-serif</item>
    </style>
    
    <style name="TextAppearance.TodoApp.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">sans-serif</item>
    </style>
    
    <!-- Button Styles -->
    <style name="Widget.TodoApp.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">24dp</item>
    </style>
    
    <style name="Widget.TodoApp.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">24dp</item>
    </style>
    
    <style name="Widget.TodoApp.Button.Text" parent="Widget.Material3.Button.TextButton">
    </style>
    
    <!-- Card Styles -->
    <style name="Widget.TodoApp.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
    </style>
    
    <!-- Chip Styles -->
    <style name="Widget.TodoApp.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">20dp</item>
    </style>
    
    <!-- Dialog Theme -->
    <style name="Theme.TodoApp.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="dialogCornerRadius">16dp</item>
    </style>
    
    <!-- Bottom Sheet Theme -->
    <style name="Theme.TodoApp.BottomSheet" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.TodoApp.BottomSheet</item>
    </style>
    
    <style name="Widget.TodoApp.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.TodoApp.BottomSheet</item>
    </style>
    
    <style name="ShapeAppearance.TodoApp.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
    </style>
    
    <!-- Circular Image View Style -->
    <style name="CircularImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
    
</resources>
